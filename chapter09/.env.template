# Chapter 9: Software Development Agents
# Book: "Agents" by Imran Ahmad (Packt, 2026)
#
# Copy this file to .env and add your API key:
#   cp .env.template .env
#
# Leave the value blank to run in Simulation Mode (no API key required).
# Simulation Mode uses MockLLM to demonstrate all agent behaviors
# with chapter-accurate mock responses.

OPENAI_API_KEY=

# Multi-provider support (added for Anthropic and Google Gemini testing)
# Set LLM_PROVIDER to choose: openai | anthropic | google | auto
# "auto" (default) uses the first available key in order: OpenAI → Anthropic → Google
LLM_PROVIDER=auto

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
