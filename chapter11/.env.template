# Chapter 11: Multi-Modal Perception Agents
# Book: 30 Agents Every AI Engineer Must Build
# Author: Imran Ahmad | Publisher: Packt Publishing
#
# Copy this file to .env and replace the placeholder with your token.
# Leave the value empty to run in Simulation Mode (no GPU required).
#
# To obtain a Hugging Face token:
#   1. Create an account at https://huggingface.co
#   2. Accept the LLaVA 1.5 license at https://huggingface.co/llava-hf/llava-1.5-7b-hf
#   3. Generate a token at https://huggingface.co/settings/tokens

HUGGINGFACE_TOKEN=your_hugging_face_token_here

# Multi-provider support (added for Anthropic and Google Gemini testing)
# Set LLM_PROVIDER to choose: openai | anthropic | google | auto
# "auto" (default) uses the first available key in order: OpenAI → Anthropic → Google
LLM_PROVIDER=auto

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
